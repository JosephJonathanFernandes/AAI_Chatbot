# College AI Assistant - Environment Configuration
# Copy this file to .env and fill in your actual values

# Groq API Configuration
# Get your API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Ollama Configuration (for local LLM fallback)
OLLAMA_BASE_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=mistral

# Optional: Logging level
LOG_LEVEL=INFO

# Optional: Database path
DATABASE_PATH=chatbot.db

# Optional: Model paths
INTENT_MODEL_PATH=intent_model.pkl
VECTORIZER_MODEL_PATH=tfidf_vectorizer.pkl

# Optional: Data paths
INTENTS_JSON_PATH=data/intents.json
COLLEGE_DATA_JSON_PATH=data/college_data.json

# Optional: Chat UI Configuration
CHAT_MAX_HISTORY=5
RESPONSE_MAX_LENGTH=1000
CONFIDENCE_THRESHOLD=0.5
